VITE_SUPABASE_URL=https://voghreoyuebgrvvavlxn.supabase.co
VITE_SUPABASE_ANON_KEY=your-publishable-key-here

# Optional: show Settings → “Developer (ICS test)” to email a sample .ics via Resend (Netlify only; set to true on a test site).
# VITE_ENABLE_ICS_DEV_TOOL=true

# Netlify Functions (public PDF link, performance reports): service role from Supabase → Settings → API.
# Use these exact names (Linux is case-sensitive). Lowercase superbase_* variants are also read by functions.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Same publishable (anon) key as VITE_SUPABASE_ANON_KEY — required for functions that validate the user JWT (e.g. send-dev-ics-test).
# Can duplicate VITE_SUPABASE_ANON_KEY here or set SUPABASE_ANON_KEY explicitly.
# SUPABASE_ANON_KEY=

# Optional: production site origin for agreement PDF logo fetch (defaults to window.location.origin in browser)
# VITE_PUBLIC_SITE_URL=https://your-site.netlify.app
