VITE_SUPABASE_URL=https://voghreoyuebgrvvavlxn.supabase.co
VITE_SUPABASE_ANON_KEY=your-publishable-key-here

# Optional legacy override. The public /forms/previous-clients page reads owner UUID from partnership_roll_public_owner (id=1) instead.
# DB: insert into partnership_roll_public_owner (id, artist_user_id) values (1, '<uuid>') on conflict (id) do update set artist_user_id = excluded.artist_user_id;
VITE_PARTNERSHIP_ROLL_OWNER_ID=

# Netlify Functions (public PDF link, performance reports): service role from Supabase → Settings → API.
# Use these exact names (Linux is case-sensitive). Lowercase superbase_* variants are also read by functions.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional: public site origin (no trailing slash). Used for shareable /forms/previous-clients links, Open Graph
# absolute image URLs at build (social-card.png), and in-app absolute URLs. Defaults to window.location.origin in browser.
# VITE_PUBLIC_SITE_URL=https://your-site.netlify.app

# Email Queue usage vs Resend. Prefer Settings → Email queue → offsets (per user). Optional: same via build env
# (merged with process.env on Netlify). Shown count = Settings + optional VITE_* + id-backed sends from DB.
# VITE_RESEND_DAILY_EMAIL_CAP=100
# VITE_RESEND_MONTHLY_EMAIL_CAP=3000
# VITE_RESEND_USAGE_DAY_OFFSET=0
# VITE_RESEND_USAGE_MONTH_OFFSET=0
